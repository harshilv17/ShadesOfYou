{{- 'product-grid.css' | asset_url | stylesheet_tag -}}

{%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
{%- assign filter_tags = current_tags -%}

<section class="product-grid-section section-{{ section.id }}">
  <div class="page-width">

    {%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
      <div class="product-grid__toolbar">
        <p class="product-grid__count">
          {{ 'collections.general.items_with_count' | t: count: collection.products_count }}
        </p>

        {%- if section.settings.enable_sorting -%}
          <div class="product-grid__sort">
            <label for="SortBy" class="visually-hidden">{{ 'collections.general.sort_by_label' | t }}</label>
            <select id="SortBy" name="sort_by" data-sort-select>
              {%- assign sort_options = 'manual,best-selling,title-ascending,title-descending,price-ascending,price-descending,created-ascending,created-descending' | split: ',' -%}
              {%- for option in sort_options -%}
                <option
                  value="{{ option }}"
                  {% if option == sort_by %}selected{% endif %}
                >
                  {{ 'collections.general.sort_options.' | append: option | replace: '-', '_' | t }}
                </option>
              {%- endfor -%}
            </select>
          </div>
        {%- endif -%}

        {%- if section.settings.enable_filtering -%}
          <div class="product-grid__filters">
            {%- for filter in collection.filters -%}
              {%- if filter.type == 'tag' -%}
                <button class="filter-btn{% if filter.active_values.size > 0 %} filter-btn--active{% endif %}" data-filter-toggle="{{ filter.label }}">
                  {{ filter.label }}
                  {%- render 'icon-chevron-down' -%}
                </button>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <ul
      class="product-grid columns-{{ section.settings.columns_desktop }}"
      id="ProductGrid"
      role="list"
    >
      {%- for product in collection.products -%}
        <li class="product-grid__item">
          {%- render 'product-card', product: product -%}
        </li>
      {%- else -%}
        <li class="product-grid__empty">
          <p>No products found in this collection.</p>
        </li>
      {%- endfor -%}
    </ul>

    {%- if paginate.pages > 1 -%}
      {%- render 'pagination', paginate: paginate -%}
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Product Grid",
  "tag": "section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 12
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "label": "Enable filtering",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "label": "Enable sorting",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sale_badge",
      "label": "Show sale badge",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_quick_add",
      "label": "Show Quick Add button",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Product Grid"
    }
  ]
}
{% endschema %}
