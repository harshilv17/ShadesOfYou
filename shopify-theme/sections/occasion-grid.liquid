{{- 'occasion-grid.css' | asset_url | stylesheet_tag -}}

<section class="occasion-grid section-{{ section.id }}" id="OccasionGrid">
  <div class="occasion-grid__hero">
    {%- if section.settings.hero_image != blank -%}
      {{
        section.settings.hero_image
        | image_url: width: 1400
        | image_tag:
          loading: 'eager',
          class: 'occasion-grid__hero-bg',
          sizes: '100vw'
      }}
    {%- endif -%}
    <div class="occasion-grid__hero-content">
      {%- if section.settings.tagline != blank -%}
        <p class="occasion-grid__tagline">{{ section.settings.tagline }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h1 class="occasion-grid__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="occasion-grid__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
      {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
        <a href="{{ section.settings.cta_url }}" class="btn btn--primary">
          {{ section.settings.cta_label }}
        </a>
      {%- endif -%}
    </div>
  </div>

  <div class="occasion-grid__cards page-width">
    {%- for block in section.blocks -%}
      {%- if block.type == 'occasion_card' -%}
        <a
          href="{{ block.settings.url }}"
          class="occasion-card"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.image != blank -%}
            <div class="occasion-card__media">
              {{
                block.settings.image
                | image_url: width: 600
                | image_tag:
                  loading: 'lazy',
                  class: 'occasion-card__img',
                  sizes: '(min-width: 990px) 25vw, (min-width: 750px) 50vw, 100vw'
              }}
            </div>
          {%- else -%}
            <div class="occasion-card__media occasion-card__media--placeholder">
              {{ block.settings.label | slice: 0 | upcase }}
            </div>
          {%- endif -%}
          <div class="occasion-card__body">
            {%- if block.settings.label != blank -%}
              <p class="occasion-card__label">{{ block.settings.label }}</p>
            {%- endif -%}
            {%- if block.settings.title != blank -%}
              <h3 class="occasion-card__title">{{ block.settings.title }}</h3>
            {%- endif -%}
            <span class="occasion-card__cta">Shop Now →</span>
          </div>
        </a>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Occasion Grid",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero background image"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Curated for You"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Occasion Edit"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover handcrafted pieces for every moment"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop All"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "occasion_card",
      "name": "Occasion Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label (e.g. Everyday Edit)",
          "default": "Everyday Edit"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Work Day"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Occasion Grid",
      "blocks": [
        {
          "type": "occasion_card",
          "settings": {
            "label": "Everyday Edit",
            "title": "Work Day"
          }
        },
        {
          "type": "occasion_card",
          "settings": {
            "label": "Festive Season",
            "title": "Festive"
          }
        },
        {
          "type": "occasion_card",
          "settings": {
            "label": "Off-Duty",
            "title": "Weekend"
          }
        },
        {
          "type": "occasion_card",
          "settings": {
            "label": "Thoughtful Giving",
            "title": "Gift"
          }
        }
      ]
    }
  ]
}
{% endschema %}
