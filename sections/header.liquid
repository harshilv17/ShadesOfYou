<nav class="nav" id="siteNav">
  <div class="nav__inner">
    <button class="nav__hamburger" aria-label="Menu" aria-expanded="false" aria-controls="MobileNav">
      <span class="hamburger"></span>
    </button>

    <div class="nav__left">
      {%- for link in section.settings.menu_left.links -%}
        <a href="{{ link.url }}" class="nav__link{% if link.active %} active-link{% endif %}">{{ link.title }}</a>
      {%- endfor -%}
    </div>

    <a class="nav__logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        {{ section.settings.logo | image_url: width: 200 | image_tag: alt: shop.name, loading: 'eager' }}
      {%- else -%}
        Shades <em>of</em> You
      {%- endif -%}
    </a>

    <div class="nav__right">
      {%- for link in section.settings.menu_right.links -%}
        <a href="{{ link.url }}" class="nav__link{% if link.active %} active-link{% endif %}">{{ link.title }}</a>
      {%- endfor -%}

      <a href="{{ routes.search_url }}" class="nav__icon" aria-label="Search">
        <svg width="17" height="17" viewBox="0 0 17 17" fill="none"><circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.3"/><path d="M11.5 11.5L15 15" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
      </a>
      <a href="{{ routes.cart_url }}" class="nav__icon" aria-label="Cart">
        <svg width="17" height="17" viewBox="0 0 17 17" fill="none"><path d="M3 1.5H1M3 1.5L5.5 11.5H14.5L16 5H4.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/><circle cx="7" cy="14.5" r="1" fill="currentColor"/><circle cx="13" cy="14.5" r="1" fill="currentColor"/></svg>
        <span class="nav__cart-count{% if cart.item_count == 0 %} hidden{% endif %}" data-cart-count>{{ cart.item_count }}</span>
      </a>
    </div>
  </div>
</nav>

<nav class="mobile-nav" id="MobileNav" aria-label="Mobile navigation">
  <ul class="mobile-nav__list" role="list">
    {%- for link in section.settings.menu_left.links -%}
      <li><a href="{{ link.url }}" class="mobile-nav__link">{{ link.title }}</a></li>
    {%- endfor -%}
    {%- for link in section.settings.menu_right.links -%}
      <li><a href="{{ link.url }}" class="mobile-nav__link">{{ link.title }}</a></li>
    {%- endfor -%}
  </ul>
</nav>

{% schema %}
{
  "name": "Header",
  "class": "section-header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image",
      "info": "Leave blank to use text logo"
    },
    {
      "type": "link_list",
      "id": "menu_left",
      "label": "Left navigation menu",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "menu_right",
      "label": "Right navigation menu",
      "info": "Links shown to the right of the logo (e.g. Shop All, About, Contact)"
    }
  ]
}
{% endschema %}
