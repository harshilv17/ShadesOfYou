<style>
  .section-favourites {
    padding: 64px 20px 48px;
    background: var(--surface);
  }
  .scroll-row {
    display: flex; gap: 14px; overflow-x: auto; padding-bottom: 8px;
    scrollbar-width: none; -ms-overflow-style: none; scroll-snap-type: x mandatory;
    position: relative;
  }
  .scroll-row::-webkit-scrollbar { display: none; }
  .scroll-row-wrap { position: relative; }
  .scroll-arrow {
    position: absolute; right: 0; top: 50%; transform: translateY(-50%);
    width: 36px; height: 36px; background: var(--surface);
    border: 1px solid var(--outline-ghost); border-radius: 0;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; z-index: 5; box-shadow: -8px 0 20px rgba(253,249,241,0.8);
    transition: all 0.2s;
  }
  .scroll-arrow:hover { background: var(--primary); color: var(--on-primary); border-color: var(--primary); }
  
  .product-card-sm {
    flex: 0 0 155px; cursor: pointer; scroll-snap-align: start; text-decoration: none;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  @media (min-width: 768px) {
    .product-card-sm { flex: 0 0 180px; }
  }
  .product-card-sm:hover { transform: translateY(-3px); }
  .product-card-sm:hover .card-img-wrap img { transform: scale(1.05); }

  .card-img-wrap {
    background: var(--surface-low); aspect-ratio: 3/4; overflow: hidden; margin-bottom: 10px;
  }
  .card-img-wrap img {
    width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .card-name {
    font-family: var(--font-body); font-size: 13px; font-weight: 500; color: var(--primary);
    margin-bottom: 3px; line-height: 1.3; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .card-price {
    font-family: var(--font-body); font-size: 13px; color: var(--primary); opacity: 0.6; font-weight: 400;
  }
</style>

<section class="section-favourites reveal">
  <div class="section-head">
    <span class="label-sm">{{ section.settings.eyebrow }}</span>
    <span class="script">{{ section.settings.heading | strip_html }}</span>
  </div>
  <div class="scroll-row-wrap">
    <div class="scroll-row" id="fav-scroll-{{ section.id }}">
      {%- assign featured = section.settings.collection -%}
      {%- if featured != blank -%}
        {%- assign max_show = section.settings.products_to_show -%}
        {%- for product in featured.products limit: max_show -%}
          {%- render 'product-card', product: product, is_small: true -%}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..5) -%}
          <div class="product-card-sm">
            <div class="card-img-wrap">{{ 'product-' | append: i | placeholder_svg_tag: 'occ-img' }}</div>
            <div class="card-name">Sample Product</div>
            <div class="card-price">₹1,999</div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
    <button class="scroll-arrow" onclick="document.getElementById('fav-scroll-{{ section.id }}').scrollBy({ left: 170, behavior: 'smooth' });" aria-label="Scroll right">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Customer Favourites" },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Most Loved</p>"
    },
    { "type": "collection", "id": "collection", "label": "Collection" },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 4, "max": 16, "step": 1, "default": 8
    }
  ],
  "presets": [
    { "name": "Featured Collection" }
  ]
}
{% endschema %}
