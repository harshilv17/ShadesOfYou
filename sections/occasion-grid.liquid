<style>
  .section-occasion {
    padding: 48px 20px 32px;
    background: var(--background);
  }
  .occasion-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  @media (min-width: 768px) {
    .occasion-grid { gap: 14px; }
  }
  @media (min-width: 1024px) {
    .occasion-grid { grid-template-columns: repeat(4, 1fr); max-width: 1360px; margin: 0 auto; }
    .occasion-card { aspect-ratio: 4/5 !important; }
  }
  .occasion-card {
    position: relative;
    aspect-ratio: 1/1;
    overflow: hidden;
    cursor: pointer;
    text-decoration: none;
    display: block;
  }
  .occasion-card:hover .occ-img { transform: scale(1.06); }
  .occ-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    display: block;
  }
  .occ-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(59,35,20,0.6) 0%, transparent 60%);
    display: flex;
    align-items: flex-end;
    padding: 18px;
    transition: background 0.3s;
  }
  .occasion-card:hover .occ-overlay {
    background: linear-gradient(to top, rgba(59,35,20,0.7) 0%, transparent 65%);
  }
  .occ-label {
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 400;
    color: #fff;
    line-height: 1.2;
    text-shadow: 0 1px 6px rgba(59,35,20,0.25);
  }
</style>

<section class="section-occasion reveal">
  <div class="section-head">
    <span class="label-sm">{{ section.settings.heading | strip_html }}</span>
  </div>
  
  <div class="occasion-grid">
    {%- for block in section.blocks -%}
      <a class="occasion-card" href="{{ block.settings.url | default: '#' }}" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          {{ block.settings.image | image_url: width: 800 | image_tag: class: 'occ-img', loading: 'lazy' }}
        {%- else -%}
          {{ 'collection-1' | placeholder_svg_tag: 'occ-img' }}
        {%- endif -%}
        <div class="occ-overlay">
          <span class="occ-label">{{ block.settings.title }}</span>
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Shop by Occasion",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Occasion"
    }
  ],
  "blocks": [
    {
      "type": "occasion_card",
      "name": "Occasion Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Card image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Work Day<br>Wear" },
        { "type": "url", "id": "url", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Occasion",
      "blocks": [
        { "type": "occasion_card", "settings": { "title": "Work Day<br>Wear" } },
        { "type": "occasion_card", "settings": { "title": "Festive<br>Season" } },
        { "type": "occasion_card", "settings": { "title": "Weekend<br>Easy" } },
        { "type": "occasion_card", "settings": { "title": "Gift with<br>Love" } }
      ]
    }
  ]
}
{% endschema %}
