<section class="occasion">
  <div class="occasion__hd">
    <div>
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="section-title" style="font-size:clamp(36px,5vw,58px)">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>
    {%- if section.settings.subheading != blank -%}
      <p class="occasion__sub-hd">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  <div class="occasion__grid">
    {%- assign block_count = section.blocks.size -%}
    {%- for block in section.blocks -%}
      {%- if block.settings.half_height -%}
        {%- comment %}Start a stack column for half-height cards{% endcomment -%}
      {%- else -%}
        <a class="ocard" href="{{ block.settings.url | default: '#' }}" {{ block.shopify_attributes }}>
          <div class="ocard__ph">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1400 | image_tag: loading: 'lazy', sizes: '(min-width: 1024px) 33vw, 100vw' }}
            {%- endif -%}
          </div>
          <div class="ocard__gr"></div>
          <div class="ocard__corner"></div>
          <div class="ocard__bd">
            {%- if block.settings.label != blank -%}
              <span class="ocard__tag">{{ block.settings.label }}</span>
            {%- endif -%}
            {%- if block.settings.title != blank -%}
              <h3 class="ocard__nm">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <p class="ocard__ds">{{ block.settings.description }}</p>
            {%- endif -%}
            <span class="btn-ghost-light">Explore <svg width="13" height="9" viewBox="0 0 13 9" fill="none"><path d="M1 4.5H12M8 1L12 4.5L8 8" stroke="white" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          </div>
        </a>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <div class="occasion__ft">
    {%- if section.settings.footer_note != blank -%}
      <p class="occasion__ft-note">{{ section.settings.footer_note }}</p>
    {%- endif -%}
    {%- if section.settings.view_all_label != blank -%}
      <a class="occasion__all" href="{{ section.settings.view_all_url | default: collections.all.url }}">
        {{ section.settings.view_all_label }}
        <svg width="15" height="9" viewBox="0 0 15 9" fill="none"><path d="M1 4.5H14M10 1L14 4.5L10 8" stroke="#A85B38" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Occasion Grid",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Curated for you"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>The <em>Occasion</em><br>Edit</p>"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Not sure where to start? Let your occasion guide you — every piece, handcrafted for exactly that moment."
    },
    {
      "type": "text",
      "id": "footer_note",
      "label": "Footer note",
      "default": "Every piece is handcrafted. No two are exactly alike."
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "See all styles"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "View all link"
    }
  ],
  "blocks": [
    {
      "type": "occasion_card",
      "name": "Occasion Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Card image" },
        { "type": "text", "id": "label", "label": "Label", "default": "Everyday Edit" },
        { "type": "text", "id": "title", "label": "Title", "default": "Work Day<br>Wear" },
        { "type": "text", "id": "description", "label": "Description", "default": "Breathable, polished, easy to move in." },
        { "type": "url", "id": "url", "label": "Link" },
        { "type": "checkbox", "id": "half_height", "label": "Half height (for stacked layout)", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "Occasion Grid",
      "blocks": [
        { "type": "occasion_card", "settings": { "label": "Everyday Edit", "title": "Work Day<br>Wear" } },
        { "type": "occasion_card", "settings": { "label": "Festive Season", "title": "Puja &<br>Festive" } },
        { "type": "occasion_card", "settings": { "label": "Off-Duty", "title": "Weekend Easy" } },
        { "type": "occasion_card", "settings": { "label": "Thoughtful Giving", "title": "Gift with Love" } }
      ]
    }
  ]
}
{% endschema %}
