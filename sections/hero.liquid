<style>
  .hero {
    position: relative;
    overflow: hidden;
    min-height: 480px;
    background: var(--surface-low);
  }
  .hero-img {
    width: 100%;
    height: 60vh;
    min-height: 500px;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: transform 8s ease;
  }
  .hero:hover .hero-img { transform: scale(1.03); }

  .hero-card {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--background);
    padding: 30px 24px 36px;
  }
  @media (min-width: 600px) {
    .hero-card {
      bottom: 40px;
      left: 24px;
      right: auto;
      width: 420px;
      background: rgba(247, 243, 235, 0.92);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
    }
  }
  @media (min-width: 1024px) {
    .hero-img { height: 80vh; min-height: 600px; }
    .hero-card { bottom: 60px; left: 48px; }
  }
  
  .hero-headline {
    font-family: var(--font-heading);
    font-size: clamp(34px, 4vw, 42px);
    font-weight: 300;
    line-height: 1.18;
    margin-bottom: 14px;
    color: var(--primary);
  }
  .hero-headline em {
    font-style: italic;
    color: var(--accent);
  }
  .hero-subtext {
    font-size: 14px;
    line-height: 1.65;
    letter-spacing: 0.02em;
    color: var(--primary);
    opacity: 0.7;
    margin-bottom: 24px;
  }
  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }
</style>

<section class="hero" id="HeroSection">
  {%- if section.settings.image != blank -%}
    {{ section.settings.image | image_url: width: 2000 | image_tag: class: 'hero-img', loading: 'eager', sizes: '100vw' }}
  {%- else -%}
    {{ 'lifestyle-1' | placeholder_svg_tag: 'hero-img' }}
  {%- endif -%}

  <div class="hero-card">
    {%- if section.settings.heading != blank -%}
      <h1 class="hero-headline">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="hero-subtext">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="hero-actions">
      {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_url }}" class="btn-primary">
          {{ section.settings.cta_label }} &rarr;
        </a>
      {%- endif -%}
      {%- if section.settings.cta2_label != blank -%}
        <a href="{{ section.settings.cta2_url }}" class="btn-secondary">{{ section.settings.cta2_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Cover",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Crafted by hand. Made for <em>you.</em></p>"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Premium everyday ethnic wear in handcrafted batik. Where traditional craft meets modern living."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Primary button label",
      "default": "SHOP NEW"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "cta2_label",
      "label": "Secondary button label",
      "default": "EXPLORE COLLECTIONS"
    },
    {
      "type": "url",
      "id": "cta2_url",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "Hero Cover"
    }
  ]
}
{% endschema %}
