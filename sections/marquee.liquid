<div class="marquee">
  <div class="marquee__track">
    {%- for block in section.blocks -%}
      <span class="marquee__item" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
      <span class="marquee__sep">·</span>
    {%- endfor -%}
    {%- for block in section.blocks -%}
      <span class="marquee__item">{{ block.settings.text }}</span>
      <span class="marquee__sep">·</span>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Marquee Bar",
  "tag": "section",
  "settings": [],
  "blocks": [
    {
      "type": "text",
      "name": "Marquee item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Handcrafted Batik"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee Bar",
      "blocks": [
        { "type": "text", "settings": { "text": "Organic Fabrics" } },
        { "type": "text", "settings": { "text": "Handcrafted Batik" } },
        { "type": "text", "settings": { "text": "Worldwide Shipping" } },
        { "type": "text", "settings": { "text": "Made with Intention" } },
        { "type": "text", "settings": { "text": "Size XXS – 6XL" } },
        { "type": "text", "settings": { "text": "Wax-Resist Printing" } }
      ]
    }
  ]
}
{% endschema %}
