<div class="coll">
  <div class="coll__hero">
    <div class="coll__hero-img">
      {%- if collection.image -%}
        {{ collection.image | image_url: width: 1400 | image_tag: loading: 'eager', sizes: '100vw' }}
      {%- elsif section.settings.fallback_image != blank -%}
        {{ section.settings.fallback_image | image_url: width: 1400 | image_tag: loading: 'eager', sizes: '100vw' }}
      {%- endif -%}
    </div>
    <div class="coll__hero-grad"></div>
    <div class="coll__hero-txt">
      {%- if section.settings.show_breadcrumb -%}
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="{{ routes.root_url }}">Home</a>
          <span>/</span>
          <span>{{ collection.title }}</span>
        </nav>
      {%- endif -%}

      {%- if collection.metafields.custom.tag_label != blank -%}
        <span class="coll__hero-tag">{{ collection.metafields.custom.tag_label }}</span>
      {%- elsif section.settings.tag_label != blank -%}
        <span class="coll__hero-tag">{{ section.settings.tag_label }}</span>
      {%- endif -%}

      <h1 class="coll__hero-title">{{ collection.title }}</h1>

      {%- if collection.description != blank -%}
        <p class="coll__hero-sub">{{ collection.description | strip_html | truncatewords: 30 }}</p>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collection Hero",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "fallback_image", "label": "Fallback hero image" },
    { "type": "text", "id": "tag_label", "label": "Tag label" },
    { "type": "checkbox", "id": "show_breadcrumb", "label": "Show breadcrumb", "default": true }
  ]
}
{% endschema %}
