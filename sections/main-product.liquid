{%- assign selected_variant = product.selected_or_first_available_variant -%}

<section class="prod-pg" id="MainProduct">
  <div class="prod-pg__inner">

    <!-- Gallery -->
    <div class="prod-pg__gallery" id="ProductGallery">
      <div class="prod-pg__slides" id="ProductSlides">
        {%- for media in product.media -%}
          <div class="prod-pg__slide" data-slide-index="{{ forloop.index0 }}" data-media-type="{{ media.media_type }}">
            {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
              <div class="prod-pg__video-wrap">
                {{ media | media_tag: autoplay: false, controls: true, loading: 'lazy' }}
              </div>
            {%- else -%}
              <button class="prod-pg__zoom-trigger" type="button" data-open-zoom="{{ media | image_url: width: 1800 }}" aria-label="Zoom image">
                {%- if forloop.first -%}
                  {{ media | image_url: width: 1000 | image_tag: loading: 'eager', fetchpriority: 'high', sizes: '(min-width: 900px) 50vw, 100vw' }}
                {%- else -%}
                  {{ media | image_url: width: 1000 | image_tag: loading: 'lazy', sizes: '(min-width: 900px) 50vw, 100vw' }}
                {%- endif -%}
              </button>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      {%- if product.media.size > 1 -%}
        <div class="prod-pg__dots" id="ProductDots">
          {%- for media in product.media -%}
            <button class="prod-pg__dot{% if forloop.first %} on{% endif %}" data-dot-index="{{ forloop.index0 }}" aria-label="Go to image {{ forloop.index }}"></button>
          {%- endfor -%}
        </div>

        <div class="prod-pg__thumbs" id="ProductThumbs">
          {%- for media in product.media -%}
            <button
              class="prod-pg__thumb{% if forloop.first %} on{% endif %}"
              data-thumb-index="{{ forloop.index0 }}"
            >
              {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
                <span class="prod-pg__thumb-play">▶</span>
                {{ media.preview_image | image_url: width: 120 | image_tag: alt: media.alt, loading: 'lazy' }}
              {%- else -%}
                {{ media | image_url: width: 120 | image_tag: alt: media.alt, loading: 'lazy' }}
              {%- endif -%}
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Zoom lightbox -->
    <div class="prod-pg__zoom-overlay" id="ZoomOverlay" aria-hidden="true">
      <div class="prod-pg__zoom-img-wrap" id="ZoomImgWrap">
        <img id="ZoomImg" src="" alt="Zoomed product image" />
      </div>
      <button class="prod-pg__zoom-close" type="button" data-close-zoom aria-label="Close zoom">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M15 5L5 15M5 5l10 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
    </div>

    <!-- Info -->
    <div class="prod-pg__info">
      <p class="eyebrow">{{ product.type }}</p>
      <h1 class="prod-pg__name">{{ product.title }}</h1>

      {%- assign rating_val = product.metafields.custom.rating_value | plus: 0 -%}
      {%- assign rating_count = product.metafields.custom.rating_count | plus: 0 -%}
      {%- if rating_count > 0 -%}
        <a class="prod-pg__rating" href="#ProductReviews">
          <span class="prod-pg__stars" aria-label="{{ rating_val }} out of 5 stars">
            {%- for i in (1..5) -%}
              {%- if rating_val >= i -%}
                <svg class="star star--full" width="14" height="14" viewBox="0 0 14 14"><path d="M7 1L8.8 4.6L13 5.2L10 8L10.6 12.2L7 10.4L3.4 12.2L4 8L1 5.2L5.2 4.6L7 1Z" fill="currentColor" stroke="currentColor" stroke-width=".8" stroke-linejoin="round"/></svg>
              {%- elsif rating_val >= i | minus: 0.5 -%}
                <svg class="star star--half" width="14" height="14" viewBox="0 0 14 14"><defs><linearGradient id="half"><stop offset="50%" stop-color="currentColor"/><stop offset="50%" stop-color="transparent"/></linearGradient></defs><path d="M7 1L8.8 4.6L13 5.2L10 8L10.6 12.2L7 10.4L3.4 12.2L4 8L1 5.2L5.2 4.6L7 1Z" fill="url(#half)" stroke="currentColor" stroke-width=".8" stroke-linejoin="round"/></svg>
              {%- else -%}
                <svg class="star star--empty" width="14" height="14" viewBox="0 0 14 14"><path d="M7 1L8.8 4.6L13 5.2L10 8L10.6 12.2L7 10.4L3.4 12.2L4 8L1 5.2L5.2 4.6L7 1Z" fill="none" stroke="currentColor" stroke-width=".8" stroke-linejoin="round"/></svg>
              {%- endif -%}
            {%- endfor -%}
          </span>
          <span class="prod-pg__rating-text">{{ rating_val }} · {{ rating_count }} {{ rating_count | pluralize: 'review', 'reviews' }}</span>
        </a>
      {%- endif -%}

      <div class="prod-pg__pricing" id="PriceContainer">
        <span class="prod-pg__price">{{ selected_variant.price | money }}</span>
        {%- if selected_variant.compare_at_price > selected_variant.price -%}
          <span class="prod-pg__mrp">{{ selected_variant.compare_at_price | money }}</span>
          {%- assign saved_pct = selected_variant.compare_at_price | minus: selected_variant.price | times: 100 | divided_by: selected_variant.compare_at_price -%}
          <span class="prod-pg__saved">{{ saved_pct }}% off</span>
        {%- endif -%}
      </div>

      <span class="prod-pg__craft-badge">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1L8.5 5H13L9.5 7.5L10.5 12L7 9.5L3.5 12L4.5 7.5L1 5H5.5L7 1Z" stroke="currentColor" stroke-width="1" stroke-linejoin="round"/></svg>
        Handcrafted Batik
      </span>

      <div class="prod-pg__divider"></div>

      {%- unless product.has_only_default_variant -%}
        {%- for option in product.options_with_values -%}
          <fieldset class="js-variant-fieldset" data-option-index="{{ forloop.index0 }}">
            <div class="prod-pg__size-lbl">
              <span>{{ option.name }}</span>
              {%- if option.name == 'Size' -%}
                <button class="prod-pg__size-guide" type="button" data-open-size-guide>Not sure? Find your size</button>
              {%- endif -%}
            </div>
            <div class="variant-options" style="margin-bottom:28px">
              {%- for value in option.values -%}
                <label class="variant-option">
                  <input
                    type="radio"
                    name="{{ option.name }}"
                    value="{{ value | escape }}"
                    {% if option.selected_value == value %}checked{% endif %}
                    data-variant-option
                  >
                  <span class="variant-option__label">{{ value }}</span>
                </label>
              {%- endfor -%}
            </div>
          </fieldset>
        {%- endfor -%}

        {%- if product.metafields.custom.model_info != blank -%}
          <p class="prod-pg__model-info">{{ product.metafields.custom.model_info }}</p>
        {%- endif -%}

        {%- if product.metafields.custom.fit_note != blank -%}
          <p class="prod-pg__fit-note">{{ product.metafields.custom.fit_note }}</p>
        {%- endif -%}
      {%- endunless -%}

      {%- assign pdp_total_inv = 0 -%}
      {%- for v in product.variants -%}
        {%- assign pdp_total_inv = pdp_total_inv | plus: v.inventory_quantity -%}
      {%- endfor -%}
      {%- if product.available and pdp_total_inv > 0 and pdp_total_inv <= 3 -%}
        <p class="prod-pg__low-stock">Only {{ pdp_total_inv }} left in stock — order soon</p>
      {%- endif -%}

      <div class="prod-pg__actions" id="MainAtcBlock">
        {%- form 'product', product, id: 'ProductForm', data-product-form: '' -%}
          <input type="hidden" name="id" value="{{ selected_variant.id }}" data-variant-id>
          <button
            type="submit"
            class="prod-pg__atc"
            {% unless selected_variant.available %}disabled{% endunless %}
          >
            {%- if selected_variant.available -%}
              Add to Cart
            {%- else -%}
              Sold Out
            {%- endif -%}
          </button>
        {%- endform -%}

        <button class="prod-pg__wish" aria-label="Add to wishlist">
          <svg width="18" height="16" viewBox="0 0 18 16" fill="none"><path d="M9 14.5C9 14.5 1.5 9.5 1.5 5C1.5 3.07 3.07 1.5 5 1.5C6.5 1.5 7.8 2.3 8.5 3.5C9.2 2.3 10.5 1.5 12 1.5C13.93 1.5 15.5 3.07 15.5 5C16.5 9.5 9 14.5 9 14.5Z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>

      {%- unless selected_variant.available -%}
        <div class="prod-pg__notify" id="NotifyMe">
          <p class="prod-pg__notify-text">This item is currently sold out. Enter your email and we'll let you know when it's back.</p>
          {%- form 'customer', id: 'NotifyForm' -%}
            <input type="hidden" name="contact[tags]" value="notify-restock,{{ product.handle }}">
            <input type="hidden" name="contact[note]" value="Restock notification for {{ product.title }} — {{ selected_variant.title }}">
            <div class="prod-pg__notify-row">
              <input type="email" name="contact[email]" class="prod-pg__notify-input" placeholder="Your email" required>
              <button type="submit" class="prod-pg__notify-btn">Notify Me</button>
            </div>
          {%- endform -%}
        </div>
      {%- endunless -%}

      <p class="prod-pg__reassurance">COD available · Easy 7-day returns · Free shipping above ₹999</p>

      <div class="prod-pg__trust">
        <div class="prod-pg__trust-item">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 2C9 2 3 4 3 9C3 12.5 5.5 15.5 9 17C12.5 15.5 15 12.5 15 9C15 4 9 2 9 2Z" stroke="currentColor" stroke-width="1.1" stroke-linejoin="round"/><path d="M6.5 9L8 10.5L11.5 7" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <span>Handcrafted</span>
        </div>
        <div class="prod-pg__trust-item">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M4 7L2 9L4 11" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 7L16 9L14 11" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/><path d="M2 9H16" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/><path d="M6 4V14" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-dasharray="2 2"/></svg>
          <span>7-day returns</span>
        </div>
        <div class="prod-pg__trust-item">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><rect x="2" y="6" width="14" height="9" rx="1.5" stroke="currentColor" stroke-width="1.1"/><path d="M5 6V4.5C5 3.12 6.12 2 7.5 2H10.5C11.88 2 13 3.12 13 4.5V6" stroke="currentColor" stroke-width="1.1"/><circle cx="9" cy="10.5" r="1.5" stroke="currentColor" stroke-width="1.1"/></svg>
          <span>COD available</span>
        </div>
        <div class="prod-pg__trust-item">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 2L11 6.5H16L12 9.5L13.5 14.5L9 11.5L4.5 14.5L6 9.5L2 6.5H7L9 2Z" stroke="currentColor" stroke-width="1.1" stroke-linejoin="round"/></svg>
          <span>Artisan made</span>
        </div>
      </div>

      <div class="prod-pg__accordions">
        {%- if product.description != blank -%}
          <div class="prod-pg__acc">
            <button class="prod-pg__acc-hd" data-accordion-toggle>
              Product Details <span class="prod-pg__acc-icon">−</span>
            </button>
            <div class="prod-pg__acc-bd open">{{ product.description }}</div>
          </div>
        {%- endif -%}

        {%- if product.metafields.custom.fabric_care != blank -%}
          <div class="prod-pg__acc">
            <button class="prod-pg__acc-hd" data-accordion-toggle>
              Fabric & Care <span class="prod-pg__acc-icon">+</span>
            </button>
            <div class="prod-pg__acc-bd">{{ product.metafields.custom.fabric_care }}</div>
          </div>
        {%- endif -%}

        <div class="prod-pg__acc">
          <button class="prod-pg__acc-hd" data-accordion-toggle>
            Shipping & Returns <span class="prod-pg__acc-icon">+</span>
          </button>
          <div class="prod-pg__acc-bd">Ships within 3–5 business days. Free shipping on orders above ₹999. Easy 7-day returns on all unworn, unwashed items.</div>
        </div>
      </div>
    </div>

  </div>

  <div class="prod-pg__craft">
    <div class="prod-pg__craft-img">
      {%- if section.settings.craft_image != blank -%}
        {{ section.settings.craft_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: 'Batik wax-resist process', sizes: '(min-width: 900px) 45vw, 100vw' }}
      {%- else -%}
        <div class="prod-pg__craft-placeholder"></div>
      {%- endif -%}
    </div>
    <div class="prod-pg__craft-text">
      <p class="prod-pg__craft-eyebrow">The Craft</p>
      <h3 class="prod-pg__craft-heading">Every print starts <em>by hand</em></h3>
      <p class="prod-pg__craft-body">Hot wax is drawn directly onto fabric. The dye fills the gaps. Where the wax cracks, colour bleeds through — each piece carrying variations that are impossible to replicate. That's not a flaw. That's batik.</p>
    </div>
  </div>

  <div class="prod-pg__reviews" id="ProductReviews">
    <h3 class="prod-pg__reviews-title">What our customers <em>say</em></h3>

    {%- if rating_count > 0 -%}
      <div class="prod-pg__reviews-summary">
        <div class="prod-pg__reviews-score">
          <span class="prod-pg__reviews-big">{{ rating_val }}</span>
          <span class="prod-pg__reviews-outof">/ 5</span>
        </div>
        <div class="prod-pg__reviews-meta">
          <span class="prod-pg__stars" aria-hidden="true">
            {%- for i in (1..5) -%}
              {%- if rating_val >= i -%}
                <svg class="star star--full" width="14" height="14" viewBox="0 0 14 14"><path d="M7 1L8.8 4.6L13 5.2L10 8L10.6 12.2L7 10.4L3.4 12.2L4 8L1 5.2L5.2 4.6L7 1Z" fill="currentColor" stroke="currentColor" stroke-width=".8" stroke-linejoin="round"/></svg>
              {%- else -%}
                <svg class="star star--empty" width="14" height="14" viewBox="0 0 14 14"><path d="M7 1L8.8 4.6L13 5.2L10 8L10.6 12.2L7 10.4L3.4 12.2L4 8L1 5.2L5.2 4.6L7 1Z" fill="none" stroke="currentColor" stroke-width=".8" stroke-linejoin="round"/></svg>
              {%- endif -%}
            {%- endfor -%}
          </span>
          <span class="prod-pg__reviews-count">Based on {{ rating_count }} {{ rating_count | pluralize: 'review', 'reviews' }}</span>
        </div>
      </div>
    {%- endif -%}

    <div class="prod-pg__reviews-list" id="ReviewsList">
      {%- comment -%}
        Reviews are injected here by Judge.me / Loox after app install.
        Until then, this container holds the empty-state prompt below.
      {%- endcomment -%}
    </div>

    <div class="prod-pg__reviews-empty" id="ReviewsEmpty">
      <p class="prod-pg__reviews-empty-text">Be the first to share your experience with this piece.</p>
      <button class="prod-pg__reviews-write" type="button" id="WriteReviewBtn">Write a Review</button>
    </div>
  </div>

  {%- assign ctl_products = product.metafields.custom.complete_the_look.value -%}
  {%- if ctl_products != blank and ctl_products.size > 0 -%}
    <div class="prod-pg__ctl">
      <h3 class="prod-pg__ctl-title">Complete the <em>look</em></h3>
      <div class="prod-pg__ctl-grid">
        <div class="prod-pg__ctl-hero">
          {%- if product.featured_image != blank -%}
            {{ product.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: product.title, sizes: '(min-width: 900px) 33vw, 100vw' }}
          {%- endif -%}
          <p class="prod-pg__ctl-current">Currently viewing</p>
        </div>
        <div class="prod-pg__ctl-items">
          {%- for item in ctl_products limit: 3 -%}
            <a class="prod-pg__ctl-card" href="{{ item.url }}">
              <div class="prod-pg__ctl-card-img">
                {%- if item.featured_image != blank -%}
                  {{ item.featured_image | image_url: width: 480 | image_tag: loading: 'lazy', alt: item.title, sizes: '(min-width: 900px) 20vw, 45vw' }}
                {%- endif -%}
              </div>
              <div class="prod-pg__ctl-card-info">
                <p class="prod-pg__ctl-card-name">{{ item.title }}</p>
                <p class="prod-pg__ctl-card-price">{{ item.price | money }}</p>
              </div>
            </a>
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  {%- if section.settings.show_recommendations -%}
    <div class="prod-pg__also">
      <h3 class="prod-pg__also-title">You may also <em>love</em></h3>
      <div class="prod-pg__also-grid" id="ProductRecommendations" data-product-id="{{ product.id }}" data-section-id="{{ section.id }}">
        {%- assign rec_seen = ',' -%}
        {%- assign rec_shown = 0 -%}
        {%- for rec in recommendations.products -%}
          {%- if rec_shown >= 4 -%}{% break %}{%- endif -%}
          {%- if rec.id == product.id -%}{% continue %}{%- endif -%}
          {%- assign rec_tok = rec.id | prepend: ',' | append: ',' -%}
          {%- unless rec_seen contains rec_tok -%}
            {%- assign rec_seen = rec_seen | append: rec.id | append: ',' -%}
            {%- assign rec_shown = rec_shown | plus: 1 -%}
            <a class="pcard" href="{{ rec.url }}">
              <div class="pcard__img">
                {%- if rec.featured_image != blank -%}
                  {{ rec.featured_image | image_url: width: 720 | image_tag: loading: 'lazy', alt: rec.title, sizes: '25vw' }}
                {%- endif -%}
                {%- if rec.compare_at_price > rec.price -%}
                  <span class="pcard__badge">Sale</span>
                {%- endif -%}
              </div>
              <p class="pcard__name">{{ rec.title }}</p>
              <p class="pcard__price">
                {%- if rec.compare_at_price > rec.price -%}<s>{{ rec.compare_at_price | money }}</s>{%- endif -%}
                <strong>{{ rec.price | money }}</strong>
              </p>
            </a>
          {%- endunless -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</section>

<div class="size-guide-overlay" id="SizeGuideOverlay" aria-hidden="true">
  <div class="size-guide" role="dialog" aria-label="Size Guide">
    <div class="size-guide__header">
      <h3 class="size-guide__title">Size Guide</h3>
      <button class="size-guide__close" type="button" data-close-size-guide aria-label="Close size guide">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M12 4L4 12M4 4l8 8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
      </button>
    </div>

    <div class="size-guide__tabs">
      <button class="size-guide__tab on" data-unit="in">Inches</button>
      <button class="size-guide__tab" data-unit="cm">CM</button>
    </div>

    <div class="size-guide__table-wrap">
      <table class="size-guide__table" data-unit-table="in">
        <thead>
          <tr><th>Size</th><th>Bust</th><th>Waist</th><th>Hip</th><th>Length</th></tr>
        </thead>
        <tbody>
          <tr><td>XS</td><td>32</td><td>26</td><td>35</td><td>44</td></tr>
          <tr><td>S</td><td>34</td><td>28</td><td>37</td><td>44</td></tr>
          <tr><td>M</td><td>36</td><td>30</td><td>39</td><td>45</td></tr>
          <tr><td>L</td><td>38</td><td>32</td><td>41</td><td>45</td></tr>
          <tr><td>XL</td><td>40</td><td>34</td><td>43</td><td>46</td></tr>
          <tr><td>XXL</td><td>42</td><td>36</td><td>45</td><td>46</td></tr>
        </tbody>
      </table>

      <table class="size-guide__table" data-unit-table="cm" style="display:none">
        <thead>
          <tr><th>Size</th><th>Bust</th><th>Waist</th><th>Hip</th><th>Length</th></tr>
        </thead>
        <tbody>
          <tr><td>XS</td><td>81</td><td>66</td><td>89</td><td>112</td></tr>
          <tr><td>S</td><td>86</td><td>71</td><td>94</td><td>112</td></tr>
          <tr><td>M</td><td>91</td><td>76</td><td>99</td><td>114</td></tr>
          <tr><td>L</td><td>97</td><td>81</td><td>104</td><td>114</td></tr>
          <tr><td>XL</td><td>102</td><td>86</td><td>109</td><td>117</td></tr>
          <tr><td>XXL</td><td>107</td><td>91</td><td>114</td><td>117</td></tr>
        </tbody>
      </table>
    </div>

    <div class="size-guide__how">
      <p class="size-guide__how-title">How to measure</p>
      <ul class="size-guide__how-list">
        <li><strong>Bust</strong> — Measure around the fullest part of your chest</li>
        <li><strong>Waist</strong> — Measure around the narrowest part of your waist</li>
        <li><strong>Hip</strong> — Measure around the widest part of your hips</li>
        <li><strong>Length</strong> — Measure from the shoulder seam to the desired hemline</li>
      </ul>
    </div>
  </div>
</div>

<div class="sticky-atc" id="StickyAtc" aria-hidden="true">
  <div class="sticky-atc__inner">
    <div class="sticky-atc__info">
      <p class="sticky-atc__name">{{ product.title }}</p>
      <p class="sticky-atc__price" id="StickyPrice">
        {{ selected_variant.price | money }}
        {%- if selected_variant.compare_at_price > selected_variant.price -%}
          <span class="sticky-atc__mrp">{{ selected_variant.compare_at_price | money }}</span>
        {%- endif -%}
      </p>
    </div>
    <button
      type="button"
      class="sticky-atc__btn"
      id="StickyAtcBtn"
      {% unless selected_variant.available %}disabled{% endunless %}
    >
      {%- if selected_variant.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
    </button>
  </div>
</div>

<script type="application/json" data-product-variants>
  {{ product.variants | json }}
</script>

{% schema %}
{
  "name": "Product Information",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_recommendations",
      "label": "Show product recommendations",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "craft_image",
      "label": "Batik craft image",
      "info": "Close-up of the wax-resist process or fabric texture. Recommended: 900×600px."
    }
  ],
  "presets": [
    { "name": "Product Information" }
  ]
}
{% endschema %}
