<footer class="footer" id="siteFooter">
  <div class="footer__top">
    <div>
      <a href="{{ routes.root_url }}" class="footer__logo">Shades <em>of</em> You</a>
      <p class="footer__tagline">{{ section.settings.tagline }}</p>
      {%- if section.settings.show_newsletter -%}
        <p class="footer__newsletter-hook">Get 10% off your first order</p>
        <p style="font-size:11px;color:rgba(255,255,255,.3);margin-top:2px">Plus early access to new drops & exclusive offers.</p>
        {%- form 'customer', id: 'FooterNewsletter' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="footer__email-row" style="margin-top:10px">
            <input class="footer__email-in" type="email" name="contact[email]" placeholder="Your email" required>
            <button class="footer__email-btn" type="submit">Get 10% Off</button>
          </div>
        {%- endform -%}
      {%- endif -%}
    </div>

    {%- for block in section.blocks -%}
      <div {{ block.shopify_attributes }}>
        {%- if block.settings.heading != blank -%}
          <span class="footer__col-title">{{ block.settings.heading }}</span>
        {%- endif -%}

        {%- case block.type -%}
          {%- when 'link_list' -%}
            {%- if block.settings.menu != blank -%}
              {%- for link in block.settings.menu.links -%}
                <a href="{{ link.url }}" class="footer__link">{{ link.title }}</a>
              {%- endfor -%}
            {%- endif -%}
          {%- when 'text' -%}
            {%- if block.settings.content != blank -%}
              <div style="font-size:12.5px;font-weight:300;color:rgba(255,255,255,.45);line-height:1.65">
                {{ block.settings.content }}
              </div>
            {%- endif -%}
        {%- endcase -%}
      </div>
    {%- endfor -%}
  </div>

  <div class="footer__bottom">
    <span class="footer__copy">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</span>
    <div class="footer__cards">
      <span class="footer__card-tag">Visa</span>
      <span class="footer__card-tag">Mastercard</span>
      <span class="footer__card-tag">Amex</span>
      <span class="footer__card-tag">UPI</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "section-footer",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Premium everyday ethnic wear in handcrafted batik. Made with intention, worn with ease."
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter signup",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Navigation column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    },
    {
      "type": "text",
      "name": "Text column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "richtext", "id": "content", "label": "Content" }
      ]
    }
  ]
}
{% endschema %}
