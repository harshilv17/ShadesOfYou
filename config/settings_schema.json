[
  {
    "name": "theme_info",
    "theme_name": "Shades of You",
    "theme_version": "1.0.0",
    "theme_author": "Shades of You",
    "theme_documentation_url": "https://www.shadesofyou.co.in",
    "theme_support_url": "https://www.shadesofyou.co.in"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_background",
        "label": "Background",
        "default": "#FAF7F2"
      },
      {
        "type": "color",
        "id": "color_foreground",
        "label": "Foreground / Body text",
        "default": "#1A1A1A"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent",
        "default": "#8B5C3A"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Border",
        "default": "#E8E0D5"
      },
      {
        "type": "color",
        "id": "color_button_background",
        "label": "Button background",
        "default": "#1A1A1A"
      },
      {
        "type": "color",
        "id": "color_button_label",
        "label": "Button label",
        "default": "#FAF7F2"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading font",
        "default": "helvetica_n4"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body font",
        "default": "helvetica_n4"
      },
      {
        "type": "range",
        "id": "font_body_size",
        "label": "Base font size",
        "min": 12,
        "max": 18,
        "step": 1,
        "unit": "px",
        "default": 14
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "label": "Page width",
        "min": 1000,
        "max": 1600,
        "step": 10,
        "unit": "px",
        "default": 1280
      },
      {
        "type": "range",
        "id": "spacing_sections",
        "label": "Vertical space between sections",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "default": 0
      }
    ]
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon image",
        "info": "Will be scaled down to 32 × 32 px"
      }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      {
        "type": "url",
        "id": "social_instagram_link",
        "label": "Instagram"
      },
      {
        "type": "url",
        "id": "social_facebook_link",
        "label": "Facebook"
      },
      {
        "type": "url",
        "id": "social_pinterest_link",
        "label": "Pinterest"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart type",
        "options": [
          { "value": "drawer", "label": "Drawer" },
          { "value": "page", "label": "Page" }
        ],
        "default": "drawer"
      }
    ]
  }
]
