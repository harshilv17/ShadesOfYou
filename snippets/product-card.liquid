{%- comment -%}
  Renders a product card.
  Accepts:
  - product: {Object} Product Liquid object
  - is_small: {Boolean} Use small horizontal continuous scroll card layout
{%- endcomment -%}

{%- if is_small -%}
  <a class="product-card-sm" href="{{ product.url }}">
    <div class="card-img-wrap">
      {%- if product.featured_image != blank -%}
        {{ product.featured_image | image_url: width: 400 | image_tag: loading: 'lazy' }}
      {%- else -%}
        <div style="width:100%;height:100%;background:var(--surface-low)"></div>
      {%- endif -%}
    </div>
    <div class="card-name">{{ product.title }}</div>
    <div class="card-price">
      {%- if product.compare_at_price > product.price -%}<s>{{ product.compare_at_price | money }}</s> {%- endif -%}
      {{ product.price | money }}
    </div>
  </a>
{%- else -%}
  <a class="product-grid-card" href="{{ product.url }}" style="text-decoration:none;">
    <div class="grid-card-img-wrap">
      {%- if product.featured_image != blank -%}
        {{ product.featured_image | image_url: width: 600 | image_tag: class: 'grid-card-img', loading: 'lazy' }}
      {%- else -%}
        <div style="width:100%;height:100%;background:var(--surface-low)"></div>
      {%- endif -%}
    </div>
    <div class="grid-card-info">
      <div class="grid-card-name">{{ product.title }}</div>
      <div class="grid-card-price">
        {%- if product.compare_at_price > product.price -%}<s>{{ product.compare_at_price | money }}</s> {%- endif -%}
        {{ product.price | money }}
      </div>
    </div>
  </a>
{%- endif -%}
